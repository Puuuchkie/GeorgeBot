DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_id_here
GUILD_ID=your_guild_id_here

# YouTube cookie (optional — helps bypass bot detection for restricted/age-gated videos)
# Get it: browser DevTools → Application → Cookies → youtube.com → copy all cookies as one line
YOUTUBE_COOKIE=

# Spotify (optional — enables /play with Spotify links)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Web UI
WEBUI_PASSWORD=changeme
WEBUI_PORT=3000
SESSION_SECRET=replace-with-a-long-random-string
